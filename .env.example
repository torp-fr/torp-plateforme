# TORP Application - Environment Variables Template
# Copy this file to .env for local development

# Application
VITE_APP_NAME=TORP
VITE_APP_ENV=development
VITE_APP_VERSION=1.0.0

# API Configuration
VITE_API_BASE_URL=http://localhost:3000/api
VITE_API_TIMEOUT=30000

# Authentication
VITE_AUTH_PROVIDER=mock
# When using real auth, set to: supabase

# Supabase Configuration (only needed if VITE_AUTH_PROVIDER=supabase)
# Get these from your Supabase project settings: https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxxxxx

# File Upload
VITE_MAX_FILE_SIZE=10485760
# Max file size in bytes (default: 10MB)
VITE_ALLOWED_FILE_TYPES=.pdf,.jpg,.jpeg,.png,.doc,.docx

# Features Flags
VITE_FEATURE_PAYMENT_ENABLED=false
VITE_FEATURE_CHAT_AI_ENABLED=true
VITE_FEATURE_MARKETPLACE_ENABLED=false
VITE_FEATURE_ANALYTICS_ENABLED=true

# ✨ FREE MODE CONFIGURATION (Phase de test gratuit)
# Set to 'true' during testing phase to provide unlimited free access
# Set to 'false' when ready to enable payments
VITE_FREE_MODE=true

# Default credits for new users (999999 = unlimited in free mode, 0 in paid mode)
VITE_DEFAULT_CREDITS=999999

# Message displayed to users during free testing phase
VITE_FREE_MODE_MESSAGE="🎉 TORP est gratuit et illimité pendant la phase de test !"

# 💳 STRIPE CONFIGURATION (désactivé par défaut pendant la phase test)
# Set to 'true' ONLY when ready to enable real payments
VITE_STRIPE_ENABLED=false

# Analytics & Monitoring
VITE_SENTRY_DSN=
VITE_ANALYTICS_ID=
VITE_HOTJAR_ID=

# AI / LLM Services
# Get OpenAI key from: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=
# Get Anthropic key from: https://console.anthropic.com/settings/keys
VITE_ANTHROPIC_API_KEY=
# Primary provider: 'openai' or 'claude'
VITE_AI_PRIMARY_PROVIDER=claude
# Enable fallback to secondary provider if primary fails
VITE_AI_FALLBACK_ENABLED=true

# Company Search System (Backend - Supabase Edge Functions only)
# These variables are set in Supabase Dashboard → Settings → Edge Functions → Secrets
# NOT needed in frontend .env file

# REQUIRED for Edge Functions:
# SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxxxxx
# CLAUDE_API_KEY=sk-ant-xxxxxxxxxxxxx

# OPTIONAL for Premium Features:
# PAPPERS_API_KEY=your_pappers_api_key_here
# Get Pappers API key from: https://www.pappers.fr/api

# OPTIONAL for Government APIs (authenticated endpoints):
# API_ENTREPRISE_TOKEN=your_api_entreprise_token
# API_ENTREPRISE_RECIPIENT=your_siret_number

# API Sirene INSEE (gratuite, officielle)
# Obtenir une clé sur https://api.insee.fr/catalogue/
# 1. Créer un compte sur https://api.insee.fr
# 2. S'abonner à l'API Sirene (gratuit)
# 3. Créer une application et récupérer la clé
VITE_INSEE_API_KEY=
VITE_INSEE_API_URL=https://api.insee.fr/api-sirene/3.11

# API Pappers (enrichissement données entreprise - payant par jeton)
# NOTE: PAPPERS_API_KEY is now managed SERVER-SIDE ONLY via Supabase Edge Functions
# The key is NOT exposed to frontend code - calls go through pappers-proxy Edge Function
# Configuration: Set PAPPERS_API_KEY in Supabase → Settings → Edge Functions → Secrets
# Documentation: https://www.pappers.fr/api

# Third-party Services
VITE_STRIPE_PUBLIC_KEY=
VITE_GOOGLE_MAPS_API_KEY=

# Development
VITE_DEBUG_MODE=true
VITE_MOCK_API=true

# ─────────────────────────────────────────────────────────────────────
# PHASE 3A — PIPELINE ORCHESTRATION (server-side / Railway worker)
# These are NOT VITE_ prefixed — backend only, set via Railway dashboard
# ─────────────────────────────────────────────────────────────────────

# Supabase server-side (service role — never expose to frontend)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# Pappers — RCS, NAF, effectifs (server-side proxy only)
# Already managed via Edge Function secret — also needed by pipeline worker
PAPPERS_API_ENDPOINT=https://api.pappers.fr/v2

# IGN Géoportail — Cadastre, PLU
IGN_API_KEY=your_ign_key_here
IGN_GEOPORTAIL_ENDPOINT=https://wxs.ign.fr

# BANO — Address validation (no key, free)
BANO_API_ENDPOINT=https://api-adresse.data.gouv.fr

# data.gouv — Certifications RGE/Qualiopi (no key, free)
DATAGOUV_API_ENDPOINT=https://www.data.gouv.fr/api/1

# Légifrance PISTE — ABF zones, regulatory texts
LEGIFRANCE_API_KEY=your_legifrance_key_here
LEGIFRANCE_API_ENDPOINT=https://sandbox.piste.gouv.fr

# OpenStreetMap Nominatim — geocoding fallback (no key, 1 req/sec)
NOMINATIM_API_ENDPOINT=https://nominatim.openstreetmap.org
NOMINATIM_USER_AGENT=TORP-App/1.0 (contact@torp.fr)

# Trustpilot (optional — paid B2B)
TRUSTPILOT_API_KEY=
TRUSTPILOT_API_ENDPOINT=https://api.trustpilot.com/v1

# Pipeline timeouts & retry
PIPELINE_TIMEOUT_MS=30000
API_CALL_TIMEOUT_MS=5000
RETRY_MAX_ATTEMPTS=3
RETRY_BACKOFF_MS=1000

# Cache TTLs
CACHE_TTL_ENTREPRISE_DAYS=30
CACHE_TTL_CERTIFICATIONS_DAYS=7
CACHE_TTL_REPUTATION_HOURS=24
CACHE_TTL_PLU_DAYS=90
CACHE_TTL_ABF_DAYS=365
CACHE_TTL_AIDES_DAYS=7

# OCR
TESSERACT_LANG=fra

# Public base URL (for QR code access links)
PUBLIC_BASE_URL=https://torp.fr

# Supabase Storage bucket names
STORAGE_BUCKET_DEVIS=devis_uploads
STORAGE_BUCKET_QRCODES=qr_codes

# JWT for pipeline API (generate: openssl rand -hex 32)
PIPELINE_JWT_SECRET=your_pipeline_jwt_secret_here
