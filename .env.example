# ════════════════════════════════════════════════════════════════════════════
# TORP — Environment Variables Template
# ════════════════════════════════════════════════════════════════════════════
#
# Copy this file to .env.local and fill in your values for local development.
# NEVER commit .env.local — it's already in .gitignore
#
# For production: use Vercel Environment Variables + Supabase Edge Function Secrets
#
# Security rules:
#   ✅ VITE_* variables are PUBLIC — bundled into the frontend JS
#   🔴 API secrets (LLM keys, Pappers, etc.) must NEVER use VITE_ prefix
#   🔴 All LLM calls go through Edge Functions (llm-completion, generate-embedding)
#
# ════════════════════════════════════════════════════════════════════════════

# ── APP CONFIGURATION ───────────────────────────────────────────────────────
VITE_APP_NAME=TORP
VITE_APP_ENV=development
VITE_APP_VERSION=1.0.0
VITE_DEBUG_MODE=true
VITE_LOG_LEVEL=debug
VITE_MOCK_API=false

# ── API (frontend → backend) ────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:3001/api
VITE_API_TIMEOUT=30000

# ── SUPABASE (PUBLIC — safe in VITE_) ───────────────────────────────────────
# URL and anon key are public — they're exposed in the Supabase dashboard
VITE_SUPABASE_URL=https://iixxzfgexmiofvmfrnuy.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── SUPABASE (PRIVATE — server / Edge Functions only) ───────────────────────
# Service role key bypasses RLS — NEVER expose in frontend
SUPABASE_URL=https://iixxzfgexmiofvmfrnuy.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── ANTHROPIC CLAUDE (server-side only) ─────────────────────────────────────
# ⚠️ NEVER add VITE_ prefix — this key must stay on the server
# All Claude calls go through Edge Function: llm-completion
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE
CLAUDE_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# ── OPENAI (server-side only) ───────────────────────────────────────────────
# ⚠️ NEVER add VITE_ prefix — this key must stay on the server
# Embeddings go through Edge Function: generate-embedding
OPENAI_API_KEY=sk-proj-YOUR_KEY_HERE

# ── GOOGLE CLOUD (server-side only) ─────────────────────────────────────────
# Vision OCR goes through Edge Function: google-vision-ocr
GOOGLE_CLOUD_PROJECT_ID=torp-project-YOUR_ID
GOOGLE_CLOUD_API_KEY=AIzaSy_YOUR_KEY_HERE
# Or use Service Account (more secure):
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ── GOOGLE MAPS (frontend — domain-restrict in GCP console) ─────────────────
# Maps/Places API key — safe in frontend IF restricted by HTTP referrer in GCP
VITE_GOOGLE_MAPS_API_KEY=AIzaSy_YOUR_MAPS_KEY_HERE

# ── PAPPERS (server-side only) ──────────────────────────────────────────────
# SIRET lookup, company data — never expose to frontend
PAPPERS_API_KEY=YOUR_PAPPERS_KEY
PAPPERS_API_ENDPOINT=https://api.pappers.fr/v2

# ── LÉGIFRANCE PISTE (server-side only) ─────────────────────────────────────
# Regulatory texts, DTU, arrêtés
LEGIFRANCE_API_KEY=YOUR_PISTE_TOKEN
# Dev/Sandbox:
LEGIFRANCE_API_ENDPOINT=https://sandbox.piste.gouv.fr
# Production (uncomment when ready):
# LEGIFRANCE_API_ENDPOINT=https://api.piste.gouv.fr

# ── INSEE SIRENE (server-side — optional, increases quota) ──────────────────
INSEE_API_KEY=YOUR_INSEE_TOKEN
INSEE_API_URL=https://api.insee.fr

# ── ADEME (open data — no key required) ─────────────────────────────────────
ADEME_RGE_API_KEY=
ADEME_DPE_ENDPOINT=https://data.ademe.fr/data-fair/api/v1/datasets

# ── IGN GÉOPORTAIL (server-side) ────────────────────────────────────────────
IGN_API_KEY=YOUR_IGN_KEY
IGN_GEOPORTAIL_ENDPOINT=https://wxs.ign.fr

# ── GEOCODING (open data — no key required) ─────────────────────────────────
BANO_API_ENDPOINT=https://api-adresse.data.gouv.fr
NOMINATIM_API_ENDPOINT=https://nominatim.openstreetmap.org
NOMINATIM_USER_AGENT=TORP/1.0 contact@torp.fr

# ── DATA.GOUV.FR (open data — no key required) ──────────────────────────────
DATAGOUV_API_ENDPOINT=https://www.data.gouv.fr/api/1

# ── EMAIL — RESEND (server-side only) ───────────────────────────────────────
RESEND_API_KEY=re_YOUR_KEY_HERE
RESEND_FROM_EMAIL=noreply@torp.fr

# ── TRUSTPILOT (server-side — optional) ─────────────────────────────────────
TRUSTPILOT_API_KEY=YOUR_TRUSTPILOT_KEY
TRUSTPILOT_API_ENDPOINT=https://api.trustpilot.com/v1

# ── SLACK (server-side — optional) ──────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXX

# ── SENTRY (PUBLIC — safe in VITE_) ─────────────────────────────────────────
# DSN is public-facing (needed by frontend SDK)
VITE_SENTRY_DSN=https://YOUR_KEY@YOUR_ORG.ingest.sentry.io/YOUR_PROJECT
SENTRY_AUTH_TOKEN=sntrys_YOUR_AUTH_TOKEN
SENTRY_ORG=torp
SENTRY_PROJECT=torp-frontend

# ── STRIPE (Phase 5 — disabled) ─────────────────────────────────────────────
VITE_STRIPE_ENABLED=false
VITE_STRIPE_PUBLIC_KEY=pk_test_YOUR_KEY
# ⚠️ Secret key — NEVER add VITE_ prefix
STRIPE_SECRET_KEY=sk_test_YOUR_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_SECRET

# ── N8N (server-side) ───────────────────────────────────────────────────────
N8N_WEBHOOK_SECRET=YOUR_N8N_SECRET

# ── EXPRESS SERVER ──────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
PUBLIC_BASE_URL=http://localhost:5173
CLIENT_URL=http://localhost:5173
# Generate with: openssl rand -hex 32
JWT_SECRET=dev_secret_CHANGE_IN_PRODUCTION_USE_32_CHAR_MIN
JWT_TOKEN_EXPIRY_SECONDS=86400
PIPELINE_JWT_SECRET=dev_pipeline_secret_CHANGE_IN_PRODUCTION

# ── PIPELINE TIMEOUTS ───────────────────────────────────────────────────────
PIPELINE_TIMEOUT_MS=120000
API_CALL_TIMEOUT_MS=30000
RETRY_MAX_ATTEMPTS=3
RETRY_BACKOFF_MS=1000

# ── STORAGE BUCKETS ─────────────────────────────────────────────────────────
STORAGE_BUCKET_DEVIS=devis_uploads
STORAGE_BUCKET_QRCODES=qr_codes
STORAGE_BUCKET_KNOWLEDGE=knowledge-documents

# ── OCR ─────────────────────────────────────────────────────────────────────
TESSERACT_LANG=fra
GOOGLE_VISION_API_KEY=AIzaSy_YOUR_KEY_HERE

# ── CACHE TTL (in days unless noted) ────────────────────────────────────────
CACHE_TTL_ENTREPRISE_DAYS=7
CACHE_TTL_CERTIFICATIONS_DAYS=30
CACHE_TTL_REPUTATION_HOURS=168
CACHE_TTL_PLU_DAYS=30
CACHE_TTL_ABF_DAYS=90
CACHE_TTL_AIDES_DAYS=14

# ── FEATURE FLAGS ───────────────────────────────────────────────────────────
VITE_FREE_MODE=true
VITE_DEFAULT_CREDITS=999999
VITE_FEATURE_PAYMENT_ENABLED=false
VITE_FEATURE_CHAT_AI_ENABLED=true
VITE_FEATURE_ANALYTICS_ENABLED=true
VITE_AI_PRIMARY_PROVIDER=claude
VITE_AI_FALLBACK_ENABLED=true
VITE_AUTH_PROVIDER=supabase

# ── FILE UPLOAD ─────────────────────────────────────────────────────────────
VITE_MAX_FILE_SIZE=104857600
VITE_ALLOWED_FILE_TYPES=.pdf,.jpg,.jpeg,.png,.doc,.docx

# ── AUTH ────────────────────────────────────────────────────────────────────
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
