# TORP Platform — Environment Variables Template
# ────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local — it contains secrets.
# ────────────────────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── OpenAI ───────────────────────────────────────────────────────────────────
# Used by: llm-completion, generate-embedding, analyze-photo, analyze-construction-photo
OPENAI_API_KEY=sk-...

# ── Anthropic ────────────────────────────────────────────────────────────────
# Used by: llm-completion (provider=anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# ── Google Cloud Vision ───────────────────────────────────────────────────────
# Used by: google-vision-ocr Edge Function (OCR fallback for scanned PDFs)
GOOGLE_CLOUD_API_KEY=AIza...
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id

# ── Pappers API ──────────────────────────────────────────────────────────────
# Used by: enrichment engine, scrape-enterprise Edge Function
PAPPERS_API_KEY=your-pappers-api-key

# ── IGN Géoportail ────────────────────────────────────────────────────────────
# Used by: context engine (cadastre / PLU lookups)
IGN_API_KEY=your-ign-api-key
IGN_GEOPORTAIL_ENDPOINT=https://wxs.ign.fr

# ── Légifrance ───────────────────────────────────────────────────────────────
LEGIFRANCE_API_KEY=your-legifrance-api-key
LEGIFRANCE_API_ENDPOINT=https://sandbox.piste.gouv.fr

# ── Trustpilot ───────────────────────────────────────────────────────────────
TRUSTPILOT_API_KEY=your-trustpilot-api-key
TRUSTPILOT_API_ENDPOINT=https://api.trustpilot.com/v1

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
CLIENT_URL=http://localhost:5173
PUBLIC_BASE_URL=http://localhost:5173

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_TOKEN_EXPIRY_SECONDS=3600
PIPELINE_JWT_SECRET=change-me-to-a-long-random-string-for-pipeline

# ── Cost Tracking & Budget Alerts ────────────────────────────────────────────
# Monthly budget in EUR — alert at 80%, 95%, 100% of budget
MONTHLY_BUDGET_EUR=100
# Optional webhook URL for cost alert notifications (e.g. Slack incoming webhook)
COST_ALERT_WEBHOOK_URL=

# ── Pipeline Tuning ──────────────────────────────────────────────────────────
PIPELINE_TIMEOUT_MS=30000
API_CALL_TIMEOUT_MS=5000
RETRY_MAX_ATTEMPTS=3
RETRY_BACKOFF_MS=1000

# ── Cache TTL ────────────────────────────────────────────────────────────────
CACHE_TTL_ENTREPRISE_DAYS=30
CACHE_TTL_CERTIFICATIONS_DAYS=7
CACHE_TTL_REPUTATION_HOURS=24
CACHE_TTL_PLU_DAYS=90
CACHE_TTL_ABF_DAYS=365
CACHE_TTL_AIDES_DAYS=7

# ── Storage ──────────────────────────────────────────────────────────────────
STORAGE_BUCKET_DEVIS=devis_uploads
STORAGE_BUCKET_QRCODES=qr_codes

# ── OCR ──────────────────────────────────────────────────────────────────────
TESSERACT_LANG=fra

# ── API Endpoints (overridable for staging/tests) ────────────────────────────
BANO_API_ENDPOINT=https://api-adresse.data.gouv.fr
DATAGOUV_API_ENDPOINT=https://www.data.gouv.fr/api/1
NOMINATIM_API_ENDPOINT=https://nominatim.openstreetmap.org
NOMINATIM_USER_AGENT=TORP-App/1.0
PAPPERS_API_ENDPOINT=https://api.pappers.fr/v2
