# ─────────────────────────────────────────────────────────────────────────────
# .env.local.FINAL.template — Complete environment variables for TORP platform
#
# Copy to .env.local and fill in your values.
# Lines starting with # are comments.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────

# Public keys (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# Server-side only (never expose in browser)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...
SUPABASE_URL=https://your-project.supabase.co

# ── OpenAI ────────────────────────────────────────────────────────────────────

OPENAI_API_KEY=sk-proj-...
# Optional: override default model
# OPENAI_MODEL=gpt-4o

# ── Anthropic Claude ──────────────────────────────────────────────────────────

ANTHROPIC_API_KEY=sk-ant-api03-...
# Optional: override default model (claude-sonnet-4-6)
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Google Cloud (Vision OCR) ─────────────────────────────────────────────────

GOOGLE_CLOUD_API_KEY=AIzaSy...
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id

# ── Pappers (enterprise enrichment — paid) ────────────────────────────────────

PAPPERS_API_KEY=your_pappers_api_key_here
# Docs: https://www.pappers.fr/api/documentation

# ── INSEE Sirene (free — optional key for premium INSEE API) ──────────────────

# Leave empty to use the free recherche-entreprises.api.gouv.fr API.
# Set this to use the official INSEE api-sirene.fr with higher rate limits.
SIRENE_API_KEY=

# ── IGN / Geoplateforme (free, no key required) ───────────────────────────────

# The IGN Geoplateforme geocoding API does not require authentication.
# No key needed for:
#   - data.geopf.fr/geocodage (Geoplateforme geocoding)
#   - apicarto.ign.fr/api (API Carto cadastre + PLU)
#   - api.bdnb.io (BDNB buildings)
#
# Optional: IGN key for premium Geoplateforme services (WMS/WMTS maps)
# IGN_API_KEY=

# ── BDNB (free, no key required) ─────────────────────────────────────────────

# Base de Données Nationale des Bâtiments — open API, no auth needed.
# Endpoint: https://api.bdnb.io/v0.2/open

# ── Application server ────────────────────────────────────────────────────────

NODE_ENV=development
PORT=3000
# API base URL for server-to-server calls
API_BASE_URL=http://localhost:3000

# ── Authentication ────────────────────────────────────────────────────────────

# JWT secret for session signing (generate with: openssl rand -base64 32)
JWT_SECRET=your-very-long-random-secret-here
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:3000

# ── Cost tracking ─────────────────────────────────────────────────────────────

# Set to 'false' to disable cost tracking inserts during development
ENABLE_COST_TRACKING=true

# ── OCR cache ────────────────────────────────────────────────────────────────

# Set to 'false' to bypass OCR cache (always call Google Vision)
ENABLE_OCR_CACHE=true

# ── Pipeline settings ────────────────────────────────────────────────────────

# Embedding model and dimensions (must match pgvector column vector(384))
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=384

# Max tokens for LLM completions
LLM_MAX_TOKENS=4096

# Timeout for external API calls (ms)
EXTERNAL_API_TIMEOUT_MS=10000

# ── Storage ───────────────────────────────────────────────────────────────────

# Supabase Storage bucket name for uploaded quotes
STORAGE_BUCKET=devis-documents
# Max upload size in bytes (default: 10MB)
MAX_UPLOAD_SIZE_BYTES=10485760

# ── Development / debug ───────────────────────────────────────────────────────

# Set to 'true' to enable verbose structured logging
DEBUG_LOGGING=false
# Set to 'true' to bypass RLS checks during local testing (use with care)
# BYPASS_RLS=false

# ── n8n webhook (optional) ────────────────────────────────────────────────────

# Set this if you use n8n for workflow automation
# N8N_WEBHOOK_URL=https://your-n8n.example.com/webhook/torp

# ── Légifrance (optional — regulation scraping) ───────────────────────────────

# Required only if using the scrape-regulations Edge Function with Légifrance.
# Register at: https://developer.aife.economie.gouv.fr
# LEGIFRANCE_CLIENT_ID=
# LEGIFRANCE_CLIENT_SECRET=
